# Krisna Media - Environment Variables
# Copy file ini, rename ke .env.local, isi dengan credentials dari Supabase

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Discord webhook URL untuk notifikasi (booking, KMC, dll)
# Bikin di Discord: Edit Channel → Integrations → Webhooks → Create Webhook
DISCORD_WEBHOOK_URL=
